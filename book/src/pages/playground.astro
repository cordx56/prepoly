---
// The full-screen playground: editor on the left, program output on the
// right. A standalone page outside the Starlight docs chrome, mirroring the
// original mdbook playground layout.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Brass Playground</title>
  </head>
  <body>
    <div id="playground" data-brass-playground>
      <section>
        <div class="brass-editor" data-editor></div>
      </section>
      <section>
        <button class="brass-exec" data-exec>Execute</button>
        <h3>stdout</h3>
        <div class="brass-out" data-stdout></div>
        <h3>stderr</h3>
        <div class="brass-out brass-err" data-stderr></div>
      </section>
    </div>
  </body>
</html>

<style>
  :root {
    --bg-color: #222224;
    --color: #efefef;
  }
  body,
  html {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    color: var(--color);
    background: var(--bg-color);
    font-family: sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  #playground {
    display: flex;
    height: 100%;
    padding: 8px;
  }
  #playground > section {
    width: 50%;
    height: 100%;
    padding: 12px;
  }
  .cz-editor {
    width: 100%;
    height: 100%;
    border: 1px solid #ccc;
  }
  .cz-exec {
    width: 100%;
    margin: 8px 0;
    padding: 8px;
    font-size: 1.2em;
    color: var(--color);
    background: var(--bg-color);
    border: 1px solid #ccc;
    cursor: pointer;
  }
  .cz-out {
    margin: 8px 0;
    padding: 12px;
    border: 1px solid #ccc;
    font-size: 1.2em;
    overflow-x: auto;
  }
  .cz-err {
    color: #c88;
  }
  .cz-out :global(pre),
  .cz-out :global(code) {
    margin: 0;
    padding: 0;
  }
</style>

<script>
  import { mountPlayground } from "../playground/playground";

  for (const el of document.querySelectorAll<HTMLElement>("[data-brass-playground]")) {
    mountPlayground(el);
  }
</script>
