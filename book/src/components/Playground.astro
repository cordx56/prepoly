---
// An embeddable Brass playground: editor on top, Execute button, stdout and
// stderr below. Used inside docs pages; the full-screen variant lives at
// /playground/. The heavy lifting (Monaco + wasm) is in src/playground.
interface Props {
  /** CSS height of the editor pane. */
  height?: string;
}
const { height = "30em" } = Astro.props;
---

<div class="brass-playground" data-brass-playground>
  <section>
    <div class="brass-editor" data-editor style={`height: ${height}`}></div>
    <button class="brass-exec" data-exec>Execute</button>
  </section>
  <section>
    <h3>stdout</h3>
    <div class="brass-out" data-stdout></div>
    <h3>stderr</h3>
    <div class="brass-out brass-err" data-stderr></div>
  </section>
</div>

<style>
  .cz-playground {
    padding: 8px 0;
  }
  .cz-playground * {
    box-sizing: border-box;
  }
  .cz-editor {
    width: 100%;
    margin: 8px 0;
    border: 1px solid #ccc;
  }
  .cz-exec {
    width: 100%;
    margin: 8px 0;
    padding: 8px;
    font-size: 1.2em;
    cursor: pointer;
  }
  .cz-out {
    margin: 8px 0;
    padding: 12px;
    border: 1px solid #ccc;
    font-size: 1.2em;
    overflow-x: auto;
  }
  .cz-err {
    color: #c88;
  }
  .cz-out :global(pre),
  .cz-out :global(code) {
    margin: 0;
    padding: 0;
  }
</style>

<script>
  import { mountPlayground } from "../playground/playground";

  for (const el of document.querySelectorAll<HTMLElement>("[data-brass-playground]")) {
    mountPlayground(el);
  }
</script>
