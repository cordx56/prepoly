// A static method called through a type alias dispatches on the alias's
// target. A plain alias (`type B = Widget`) reaches the target's statics
// unchanged; a refinement alias (`type Names = Stack { item: string }`)
// additionally pins its slot types into the built instance, exactly like the
// annotated `let s: Names = Stack.new()` form. Regression: the checker used
// to leave such calls as silent open unknowns -- `check` passed and the
// back end refused to lower the call's result temporary.

type Widget = {
    n: int64
}

fun Widget.new(n: int64) {
    return Self { n: n }
}

fun Widget.value(self) {
    return self.n
}

type B = Widget

type Stack = {
    type item
    items: Self.item[]
}

fun Stack.new() {
    return Self { items: [] }
}

fun Stack.add(self, v) {
    self.items.push(v)
}

type Names = Stack { item: string }

fun main() {
    let w = B.new(41)
    println(w.value())

    let s = Names.new()
    s.add("brass")
    println(s.items[0])
}
