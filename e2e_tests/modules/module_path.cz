// Every module is loaded with a private `_PATH` naming its own source file, as
// an absolute path. An imported module's `_PATH` is its own, not this one's, so
// a library can locate the file it was written in.
import pathlib.{ lib_path }

println(_PATH.ends_with("module_path.cz"))
println(lib_path().ends_with("pathlib.cz"))
println(_PATH != lib_path())

// The path is absolute: it names the file wherever the program is run from.
println(_PATH != "module_path.cz")
println(len(_PATH) > len("module_path.cz"))
