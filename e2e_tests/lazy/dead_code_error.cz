// @lazy: pass
// @eager: fail
//
// Lazy checking ignores an error in code execution never needs: this
// function is never called, so the run succeeds with the program's own
// output and exit code, while the whole-program check (`--eager`,
// `brass check`) still rejects it.
fun never_called() -> int32 {
    return "not an int"
}

fun main() {
    println("reachable code ran")
}
