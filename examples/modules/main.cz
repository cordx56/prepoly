// Imports types and functions from another file. Module paths follow the
// directory layout: `geometry.vec` is `geometry/vec.cz` next to this file.

import geometry.vec.{ Vec2, dot }

fun main() {
    let a = Vec2.new(3.0, 4.0)
    let b = Vec2.new(1.0, 2.0)
    let c = a.add(b)
    println("a + b = ({c.x}, {c.y})")
    println("a . b = {dot(a, b)}")
    println("|a|   = {a.length()}")
    println("2a    = ({a.scale(2.0).x}, {a.scale(2.0).y})")
}
